{
  "name": "@org/redis-rwlock",
  "version": "0.0.0",
  "private": true,
  "description": "Distributed read/write lock over Redis — Node.js reference client (thin wrapper over shared Lua)",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "gen:lua": "node scripts/gen-lua.mjs",
    "prebuild": "npm run gen:lua",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "redis": "^5 || ^6"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "redis": "^6.0.0",
    "tsdown": "^0.22.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
