{
  "name": "@org/redis-rwlock",
  "version": "0.0.0",
  "private": true,
  "description": "Distributed read/write lock over Redis — Node.js reference client (thin wrapper over shared Lua)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "gen:lua": "node scripts/gen-lua.mjs",
    "prebuild": "npm run gen:lua",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "ioredis": "^5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ioredis": "^5.4.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
